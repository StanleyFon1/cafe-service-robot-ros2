    <!-- ============================================================ -->
    <!--  SERVICE COUNTER (back of cafe)                              -->
    <!-- ============================================================ -->
    <model name="counter">
      <static>true</static>
      <pose>0 -10.4 0.75 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>5 0.6 1.5</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>5 0.6 1.5</size></box></geometry>
