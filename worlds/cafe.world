    <!-- Chairs around table1 -->
    <model name="chair_t1_n"><static>true</static><pose>-3.5 -1.9 0.75 0 0 0</pose>
      <link name="link"><collision name="col"><geometry><box><size>0.4 0.4 1.5</size></box></geometry></collision>
